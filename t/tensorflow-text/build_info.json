{
  "maintainer": "kiranNukal",
  "package_name": "tensorflow-text",
  "github_url": "https://github.com/tensorflow/text.git",
  "version": "v2.18.1",
  "wheel_build" : true,
  "package_dir": "t/tensorflow-text",
  "default_branch": "main",
  "build_script": "tensorflow_text_ubi_9.3.sh",
  "docker_build": false,
  "validate_build_script": true,
  "use_non_root_user": "false",
  "auditwheel_exclude": [
    "libtensorflow_framework.so.2",
    "libpython3.10.so.1.0",
    "libpython3.11.so.1.0",
    "libpython3.12.so.1.0",
    "libpython3.13.so.1.0",
    "libpython3.14.so.1.0"
  ],
  "v2.14.0": {
    "build_script": "tensorflow_text_ubi_9.3.sh"
  },
  "*": {
    "build_script": "tensorflow_text_2.18.1_ubi_9.3.sh"
  }
