+      posix.close(file_descriptor_);
+      if (is_anonymus_ && !anonymus_file_.empty()) {
+        posix.unlink(anonymus_file_.c_str());
+      }
+    }
+    file_descriptor_ = -1;
+  }
+  ASSERT(file_descriptor_ == -1);
