+AsyncFileContextThreadPool::~AsyncFileContextThreadPool() {
+  if (file_descriptor_ != -1) {
+    // Defensive fallback: avoid leaking open fds when close was not enqueued.
+    ENVOY_LOG_MISC(error,
+                   "AsyncFileContextThreadPool destroyed with open fd={}, closing defensively",
