+    final String key = prefix + "." + configKey;
+    settings.put(key, fileName);
+
+    final String fileErrorMessage = "cannot read configured "
+        + fileType
+        + " ["
+        + fileName
+        + "] because access to read the file is blocked; SSL resources should be placed in the ["
+        + env.configDir().toAbsolutePath().toString()
+        + "] directory";
+
+    // Expect the top-level exception from SSLService
+    Throwable exception = expectFailure(settings);
+
+    // Top-level exception message may vary: either access blocked or file missing
+    assertThat(
+        exception.getMessage(),
+        anyOf(
+            containsString("failed to load SSL configuration [" + prefix + "] - " + fileErrorMessage),
+            containsString("failed to load SSL configuration [" + prefix + "] - cannot read configured")
+        )
+    );
+    assertThat(exception, instanceOf(ElasticsearchSecurityException.class));
+
+    // Nested cause: SslConfigException
+    exception = exception.getCause();
+    assertThat(
+        exception.getMessage(),
+        anyOf(
+            containsString("because access to read the file is blocked"),
+            containsString("because the file does not exist")
+        )
+    );
+    assertThat(exception, instanceOf(SslConfigException.class));
+
+    // Nested cause: either AccessControlException or NoSuchFileException
+    exception = exception.getCause();
+    assertThat(
+        exception,
+        anyOf(
+            instanceOf(AccessControlException.class),
+            instanceOf(java.nio.file.NoSuchFileException.class)
+        )
+    );
+
+    // Ensure the exception mentions the file
+    assertThat(exception, throwableWithMessage(containsString(fileName)));
     }
 
